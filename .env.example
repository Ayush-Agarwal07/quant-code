# QuantCode environment — copy to .env and fill in. Everything has a safe default;
# the demo runs fully offline on mock + in-memory with NOTHING set here.

# --- Redis (memory substrate; D2). Local default; in-memory fallback if unreachable. ---
REDIS_URL=redis://localhost:6379/0
REDIS_NAMESPACE=qc
QC_TIER1_TTL=3600
# 🧑‍⚖️ HITL: connecting to a non-local / Redis Cloud URL is gated — opt in explicitly.
# QC_ALLOW_REMOTE_REDIS=1
# Force the no-server in-memory backend (used by demo/tests):
# QC_MEMORY_BACKEND=memory

# --- LLM (D1). Unset => mock (deterministic, offline, stage-safe). ---
# QC_LLM_PROVIDER=mock        # mock | anthropic | openai_compatible | ollama
# QC_LLM_MODEL=
# 🧑‍⚖️ HITL: the first real (non-mock) call is gated. Real-provider creds:
# ANTHROPIC_API_KEY=
# QC_OPENAI_BASE_URL=https://api.openai.com/v1
# QC_OPENAI_API_KEY=
# QC_OPENAI_MODEL=
# QC_OLLAMA_BASE_URL=http://localhost:11434
# QC_OLLAMA_MODEL=

# --- Browserbase (research-url path; committed track). ---
# 🧑‍⚖️ HITL: a live fetch spends credits + scrapes a real site — confirmed per URL.
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=

# --- Workspace artifact root. ---
QC_WORKSPACE=workspace

# --- Observability seam (off by default; documented, not wired). ---
# QC_TRACE_EXPORTER=none
