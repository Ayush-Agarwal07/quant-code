# QuantCode environment — copy to .env and fill in. Everything has a safe default;
# the whole tool runs fully offline with NOTHING set here (local SQLite + mock LLM).

# --- Memory. Default: local SQLite file. ---
# QC_DB_PATH=workspace/memory/quantcode.db
# QC_NAMESPACE=qc
# QC_MEMORY_BACKEND=sqlite     # sqlite (default) | memory (no file) | redis (opt-in)
# Redis backend (install the [redis] extra; needs RediSearch, e.g. redis-stack):
# REDIS_URL=redis://localhost:6379/0
# QC_TIER1_TTL=3600            # Redis-only working-trace TTL

# --- LLM. Unset => mock (deterministic, offline). ---
# QC_LLM_PROVIDER=mock        # mock | anthropic | openai_compatible | ollama
# QC_LLM_MODEL=
# 🧑‍⚖️ HITL: the first real (non-mock) call is gated. Real-provider creds:
# ANTHROPIC_API_KEY=
# QC_OPENAI_BASE_URL=https://api.openai.com/v1
# QC_OPENAI_API_KEY=
# QC_OPENAI_MODEL=
# QC_OLLAMA_BASE_URL=http://localhost:11434
# QC_OLLAMA_MODEL=

# --- research-url live fetch. Default: stdlib HTTP GET (no API keys). ---
# QC_BROWSER_FETCH=1          # let the pipeline fetch discovered URLs (off by default)
# QC_BROWSER_RENDER=1         # render JS via local Playwright ([browser] extra)

# --- Workspace artifact root. ---
QC_WORKSPACE=workspace
